{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RGF Import Tool",
  "version": "0.1.0",
  "identifier": "kz.smartalmaty.rgf-import",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "RGF Import Tool",
        "width": 1000,
        "height": 780,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src 'self' http://localhost:8000; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
